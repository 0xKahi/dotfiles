{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "cyberpunk-theme",
  "keybinds": {
    "leader": "ctrl+o",
    "session_share": "none",
    "sidebar_toggle": "<leader>b",
    "status_view": "<leader>s",
    "editor_open": "<leader>e",
    "session_new": "<leader>n",
    "session_list": "<leader>l",
    "session_interrupt": "esc",
    "session_compact": "<leader>c",
    "session_child_cycle": "<leader>]",
    "session_child_cycle_reverse": "<leader>[",
    "model_list": "<leader>m",
    "theme_list": "<leader>t",
    "input_clear": "ctrl+c",
    "input_paste": "ctrl+v",
    "input_submit": "enter",
    "input_newline": "shift+enter",
    "input_move_left": "left,ctrl+h",
    "input_move_right": "right,ctrl+l",
    "input_move_up": "up,ctrl+k",
    "input_move_down": "down,ctrl+j",
    "input_undo": "super+z",
    "input_redo": "super+shift+z",
    "messages_page_up": "ctrl+w+u,pgup",
    "messages_page_down": "ctrl+w+d,pgdown",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+alt+g",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "app_exit": "ctrl+c,<leader>q"
  },
  "diff_style": "auto"
}