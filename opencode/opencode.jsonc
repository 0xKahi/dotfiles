{
	"$schema": "https://opencode.ai/config.json",
	"username": "kahi",
	"layout": "stretch",
	"share": "manual",
	"autoupdate": "notify",
	"enabled_providers": ["opencode", "openrouter", "openai", "google", "anthropic", "github-copilot"],
	"plugin": ["opencode-claude-auth@latest"],
	"small_model": "opencode/gpt-5-nano",
	"server": {
		"port": 4096,
		"hostname": "127.0.0.1",
		"mdns": false,
		"cors": []
	},
	"provider": {
		"openai": {
			"options": {
				"reasoningEffort": "medium",
				"reasoningSummary": "auto",
				"textVerbosity": "medium",
				"include": ["reasoning.encrypted_content"],
				"store": false
			}
		}
	},
	"agent": {
		"plan": {
			"color": "#72F6B2"
		},
		"build": {
			"color": "#55BBF9"
		}
	},
	"mcp": {
		"context7": {
			"type": "local",
			"command": ["bunx", "-y", "@upstash/context7-mcp@latest"],
			"enabled": true
		},
		"tavily-mcp": {
			"type": "local",
			"command": ["npx", "-y", "tavily-mcp"],
			"enabled": true
		},
		"perplexity-mcp": {
			"type": "local",
			"command": ["bunx", "-y", "perplexity-mcp"],
			"enabled": false,
			"environment": {
				"PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}",
				"PERPLEXITY_TIMEOUT_MS": "600000"
			}
		},
		"firecrawl": {
			"type": "local",
			"command": ["bunx", "-y", "firecrawl-mcp"],
			"enabled": true,
			"environment": {
				"FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
			}
		},
		"coingecko_mcp": {
			"type": "remote",
			"url": "https://mcp.api.coingecko.com/sse",
			"enabled": true
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": false
		},
		"grep_app": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		}
	},
	"lsp": {
		"lua-ls": {
			"disabled": false,
			"command": ["lua-language-server"],
			"extensions": ["lua"]
		}
	},
	"permission": {
		"write": "ask",
		"edit": "ask",
		"read": "allow",
		"list": "allow",
		"grep": "allow",
		"glob": "allow",
		"task": "allow",
		"question": "allow",
		"todoread": "allow",
		"todowrite": "allow",
		"doom_loop": "ask",
		"external_directory": {
			"*": "ask",
			"/tmp/*": "allow"
		},
		"bash": {
			"*": "ask",
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git show*": "allow",
			"gh repo clone*": "allow",
			"gh repo view*": "allow",
			"ls*": "allow",
			"find*": "allow",
			"fd*": "allow",
			"rg*": "allow",
			"grep*": "allow",
			"sort*": "allow",
			"sed*": "allow",
			"cat*": "allow",
			"head*": "allow",
			"tail*": "allow",
			"comm*": "allow"
		},
		"skill": {
			"skill-creator": "ask",
			"*": "allow"
		},
		"lsp": "allow",
		"webfetch": "deny",
		"websearch": "deny",
		"codesearch": "deny",
		"context7*": "deny",
		"tavily-mcp*": "deny",
		"firecrawl*": "deny",
		"coingecko_mcp*": "deny",
		"perplexity-mcp*": "deny",
		"grep_app*": "deny",
		"exa*": "deny"
	},
	"experimental": {
		"batch_tool": true
	}
}
