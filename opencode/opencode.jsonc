{
	"$schema": "https://opencode.ai/config.json",
	"username": "kahi",
	"layout": "stretch",
	"share": "manual",
	"autoupdate": "notify",
	"default_agent": "plan",
	"enabled_providers": ["opencode", "openrouter", "openai", "google", "anthropic"],
	"plugin": ["opencode-antigravity-auth@latest", "opencode-claude-auth"],
	"small_model": "opencode/gpt-5-nano",
	"server": {
		"port": 4096,
		"hostname": "127.0.0.1",
		"mdns": false,
		"cors": []
	},
	"provider": {
		"google": {
			"models": {
				"antigravity-gemini-3-pro": {
					"name": "Gemini 3 Pro (Antigravity)",
					"limit": {
						"context": 1048576,
						"output": 65535
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					},
					"variants": {
						"low": {
							"thinkingLevel": "low"
						},
						"high": {
							"thinkingLevel": "high"
						}
					}
				},
				"antigravity-gemini-3.1-pro": {
					"name": "Gemini 3.1 Pro (Antigravity)",
					"limit": {
						"context": 1048576,
						"output": 65535
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					},
					"variants": {
						"low": {
							"thinkingLevel": "low"
						},
						"high": {
							"thinkingLevel": "high"
						}
					}
				},
				"antigravity-gemini-3-flash": {
					"name": "Gemini 3 Flash (Antigravity)",
					"limit": {
						"context": 1048576,
						"output": 65536
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					},
					"variants": {
						"minimal": {
							"thinkingLevel": "minimal"
						},
						"low": {
							"thinkingLevel": "low"
						},
						"medium": {
							"thinkingLevel": "medium"
						},
						"high": {
							"thinkingLevel": "high"
						}
					}
				},
				"gemini-3-flash-preview": {
					"name": "Gemini 3 Flash Preview (Gemini CLI)",
					"limit": {
						"context": 1048576,
						"output": 65536
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					}
				},
				"gemini-3-pro-preview": {
					"name": "Gemini 3 Pro Preview (Gemini CLI)",
					"limit": {
						"context": 1048576,
						"output": 65535
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					}
				},
				"gemini-3.1-pro-preview": {
					"name": "Gemini 3.1 Pro Preview (Gemini CLI)",
					"limit": {
						"context": 1048576,
						"output": 65535
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					}
				},
				"gemini-3.1-pro-preview-customtools": {
					"name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
					"limit": {
						"context": 1048576,
						"output": 65535
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					}
				}
			}
		},
		"openai": {
			"options": {
				"reasoningEffort": "medium",
				"reasoningSummary": "auto",
				"textVerbosity": "medium",
				"include": ["reasoning.encrypted_content"],
				"store": false
			}
		}
	},
	"agent": {
		"plan": {
			"color": "#72F6B2"
		},
		"build": {
			"color": "#55BBF9"
		}
	},
	"mcp": {
		"context7": {
			"type": "local",
			"command": ["bunx", "-y", "@upstash/context7-mcp@latest"],
			"enabled": true
		},
		"tavily-mcp": {
			"type": "local",
			"command": ["npx", "-y", "tavily-mcp"],
			"enabled": true
		},
		"perplexity-mcp": {
			"type": "local",
			"command": ["bunx", "-y", "perplexity-mcp"],
			"enabled": false,
			"environment": {
				"PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}",
				"PERPLEXITY_TIMEOUT_MS": "600000"
			}
		},
		"firecrawl": {
			"type": "local",
			"command": ["bunx", "-y", "firecrawl-mcp"],
			"enabled": true,
			"environment": {
				"FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
			}
		},
		"coingecko_mcp": {
			"type": "remote",
			"url": "https://mcp.api.coingecko.com/sse",
			"enabled": true
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": false
		},
		"grep_app": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		}
	},
	"lsp": {
		"lua-ls": {
			"disabled": false,
			"command": ["lua-language-server"],
			"extensions": ["lua"]
		}
	},
	"permission": {
		"write": "ask",
		"edit": "ask",
		"read": "allow",
		"list": "allow",
		"grep": "allow",
		"glob": "allow",
		"task": "allow",
		"question": "allow",
		"todoread": "allow",
		"todowrite": "allow",
		"doom_loop": "ask",
		"external_directory": "ask",
		"bash": {
			"*": "ask",
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"ls*": "allow",
			"find*": "allow",
			"fd*": "allow",
			"rg*": "allow",
			"grep*": "allow",
			"cat*": "allow"
		},
		"skill": {
			"skill-creator": "ask",
			"*": "allow"
		},
		"lsp": "allow",
		"webfetch": "deny",
		"websearch": "deny",
		"codesearch": "deny",
		"context7*": "deny",
		"tavily-mcp*": "deny",
		"firecrawl*": "deny",
		"coingecko_mcp*": "deny",
		"perplexity-mcp*": "deny",
		"grep_app*": "deny",
		"exa*": "deny"
	},
	"experimental": {
		"batch_tool": true
	}
}
