{
	"$schema": "https://opencode.ai/config.json",
	"username": "kahi",
	"layout": "stretch",
	"share": "manual",
	"autoupdate": "notify",
	"default_agent": "sisyphus",
	"enabled_providers": [
		"anthropic",
		"opencode",
		"openai",
		"google"
	],
	"plugin": [
		"opencode-antigravity-auth@latest",
		"oh-my-opencode@latest"
	],
	"small_model": "opencode/gpt-5-nano"
}
