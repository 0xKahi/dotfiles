{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "new_task_system_enabled": true,
  "model_fallback": true,
  "hashline_edit": false,
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "thinking": {
        "type": "enabled"
      },
      "ultrawork": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "permission": {
        "task": "allow"
      }
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "thinking": {
        "type": "enabled"
      },
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
      "fallback_models": [
        "openai/gpt-5.5"
      ]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "thinking": {
        "type": "enabled"
      },
      "fallback_models": [
        "openai/gpt-5.5",
        "anthropic/claude-sonnet-4-6",
        "opencode-go/glm-5.1",
        "opencode-go/kimi-k2.6"
      ]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "medium",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "openai/gpt-5.5",
        "opencode-go/glm-5.1"
      ],
      "color": "#ED7892",
      "permission": {
        "edit": "allow"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "permission": {
        "edit": "allow",
        "task": "allow"
      }
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "opencode-go/glm-5.1",
        "opencode-go/kimi-k2.6"
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        "opencode-go/minimax-m2.7"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "opencode-go/kimi-k2.6"
      ]
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6",
        "openai/gpt-5.5"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "description": "Frontend, UI/UX, design, animation",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "opencode-go/glm-5.1"
      ]
    },
    "ultrabrain": {
      "description": "Deep logical reasoning, complex architecture",
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "deep": {
      "description": "Autonomous problem-solving, thorough research",
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "artistry": {
      "description": "Creative/unconventional approaches",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "description": "Trivial tasks, typo fixes, single-file changes",
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "opencode/gpt-5-nano"
      ]
    },
    "unspecified-high": {
      "description": "General tasks, high effort",
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "thinking": {
        "type": "enabled"
      },
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "xhigh"
        },
        "opencode-go/glm-5.1"
      ]
    },
    "unspecified-low": {
      "description": "General tasks, low effort",
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.5",
        "opencode-go/kimi-k2.6"
      ]
    },
    "writing": {
      "description": "Documentation, prose, technical writing",
      "model": "opencode-go/kimi-k2.6"
    },
    "git": {
      "model": "opencode-go/minimax-m2.7",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 4,
      "google": 3,
      "github-copilot": 3,
      "opencode": 5,
      "opencode-go": 5,
      "openrouter": 5
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-7": 3,
      "opencode/gpt-5-nano": 20,
      "openai/gpt-5.4-mini-fast": 4
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "ralph_loop": {
    "enabled": true,
    "default_strategy": "continue",
    "default_max_iterations": 100
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "window"
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "websearch": {
    "provider": "exa"
  },
  "notification": {
    "force_enable": true
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "skills": {
    "sources": [
      {
        "path": "~/.config/opencode/skills",
        "recursive": true
      }
    ],
    "enable": [
      "caveman"
    ]
  }
}
