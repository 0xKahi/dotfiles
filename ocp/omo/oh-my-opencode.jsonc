{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		// Core Agents
		"sisyphus": {
			// Main orchestrator: Claude Opus or Kimi K2.5 work best
			"model": "opencode/kimi-k2.5",
			"ultrawork": {
				"model": "opencode/glm-5",
				"variant": "max"
			},
			"permission": {
				"task": "allow"
			}
		},
		"hephaestus": {
			"model": "openai/gpt-5.3-codex",
			"permission": {
				"edit": "allow",
				"task": "allow"
			}
		},
		"oracle": {
			// Architecture consultation: GPT-5.4 or Claude Opus
			"model": "openai/gpt-5.4",
			"variant": "high"
		},
		"librarian": {
			// Research agents: cheap fast models are fine
			"model": "openrouter/minimax/minimax-m2.7",
			"fallback_models": [
				"google/gemini-3-flash-preview"
			]
		},
		"explore": {
			"model": "openrouter/minimax/minimax-m2.7",
			"fallback_models": [
				"opencode/gpt-5-nano"
			]
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.3-codex",
			"fallback_models": [
				"google/gemini-3-flash-preview",
				"opencode/kimi-k2.5"
			]
		},
		// Planning Agents
		"prometheus": {
			//inherits sisyphus model; just add prompt guidance
			"model": "opencode/glm-5",
			"prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
			"fallback_models": [
				"openai/gpt-5.4"
			]
		},
		"metis": {
			// plan consultant
			"model": "openai/gpt-5.4",
			"fallback_models": [
				"anthropic/claude-sonnet-4-6",
				"opencode/glm-5",
				"opencode/kimi-k2.5"
			]
		},
		"momus": {
			// plan reviewer
			"model": "openai/gpt-5.4",
			"fallback_models": [
				"opencode/glm-5",
				"opencode/kimi-k2.5"
			]
		},
		"atlas": {
			// plan executer
			"model": "anthropic/claude-sonnet-4-6",
			"variant": "medium",
			"fallback_models": [
				"openai/gpt-5.4",
				"opencode/glm-5",
				"opencode/kimi-k2.5"
			]
		},
		"sisyphus-junior": {
			// category executer
			"model": "anthropic/claude-sonnet-4-6",
			"fallback_models": [
				"opencode/kimi-k2.5",
				"openai/gpt-5.4"
			]
		}
	},
	"categories": {
		// visual-engineering — Gemini dominates visual tasks
		"visual-engineering": {
			"model": "google/gemini-3.1-pro-preview",
			"variant": "high",
			"fallback_models": [
				"google/antigravity-gemini-3.1-pro",
				"opencode/glm-5"
			]
		},
		"ultrabrain": {
			"model": "openai/gpt-5.3-codex",
			"variant": "xhigh",
			"fallback_models": [
				"google/gemini-3.1-pro-preview"
			]
		},
		"deep": {
			"model": "openai/gpt-5.3-codex",
			"variant": "medium",
			"fallback_models": [
				"google/gemini-3.1-pro-preview"
			]
		},
		"artistry": {
			"model": "google/gemini-3.1-pro-preview",
			"variant": "high"
		},
		// quick — trivial tasks
		"quick": {
			"model": "openrouter/minimax/minimax-m2.7",
			"fallback_models": [
				"openai/gpt-5.4-mini",
				"opencode/gpt-5-nano"
			]
		},
		// unspecified-low — moderate tasks
		"unspecified-low": {
			"model": "anthropic/claude-sonnet-4-6",
			"fallback_models": [
				"opencode/kimi-k2.5",
				"openai/gpt-5.3-codex"
			]
		},
		// unspecified-high — complex work
		"unspecified-high": {
			"model": "openai/gpt-5.4",
			"fallback_models": [
				"opencode/glm-5",
				"openai/gpt-5.3-codex"
			]
		},
		// writing — docs/prose
		"writing": {
			"model": "google/gemini-3-flash-preview"
		},
		// Custom category for git operations
		"git": {
			"model": "opencode/gpt-5-nano",
			"description": "All git operations",
			"prompt_append": "Focus on atomic commits, clear messages, and safe operations."
		}
	},
	// Limit expensive providers; let cheap ones run freely
	"background_task": {
		"defaultConcurrency": 5,
		"providerConcurrency": {
			"anthropic": 3,
			"openai": 3,
			"google": 3,
			"opencode": 10,
			"openrouter": 10
		},
		"modelConcurrency": {
			"anthropic/claude-opus-4-6": 2,
			"opencode/gpt-5-nano": 20,
			"opencode/minimax-m2.5": 20,
			"opencode/kimi-k2.5": 5
		}
	},
	"sisyphus_agent": {
		"disabled": false,
		"default_builder_enabled": false,
		"planner_enabled": true,
		"replace_plan": true
	},
	"experimental": {
		"aggressive_truncation": true,
		"task_system": true
	},
	"tmux": {
		"enabled": true,
		"layout": "main-vertical",
		"main_pane_size": 60,
		"main_pane_min_width": 120,
		"agent_pane_min_width": 40
	},
	"browser_automation_engine": {
		"provider": "agent-browser"
	}
}
