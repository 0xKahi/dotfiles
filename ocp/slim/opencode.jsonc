{
	"$schema": "https://opencode.ai/config.json",
	"username": "kahi",
	"layout": "stretch",
	"share": "manual",
	"autoupdate": "notify",
	"default_agent": "orchestrator",
	"plugin": [
		"opencode-claude-auth@latest",
		"oh-my-opencode-slim@latest"
	],
	"small_model": "opencode/gpt-5-nano",
	"agent": {
		"orchestrator": {
			"color": "#D498F8"
		},
		"council": {
			"color": "#4fd6be"
		},
		"explore": {
			"disable": true
		},
		"general": {
			"disable": true
		},
		"plan": {
			"disable": true
		},
		"build": {
			"disable": true
		}
	}
}
