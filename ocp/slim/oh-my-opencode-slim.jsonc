{
	"$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
	"preset": "default",
	"presets": {
		"default": {
			"orchestrator": {
				"model": "anthropic/claude-opus-4-7",
				"variant": "max",
				"skills": [
					"*"
				],
				"mcps": [
					"*",
					"websearch"
				]
			},
			"oracle": {
				"model": "openai/gpt-5.5",
				"variant": "high",
				"skills": [],
