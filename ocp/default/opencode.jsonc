{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [
		"~/.config/ocp/default/INSTRUCTIONS.md",
		"~/.config/ocp/default/SUBAGENT_GUIDE.md"
	],
	"plugin": [
		"opencode-claude-auth@latest",
		"@tarquinen/opencode-dcp@latest"
	],
	"small_model": "opencode/gpt-5-nano",
	"agent": {
		"general": {
			"mode": "subagent"
		},
		"explore": {
			"mode": "subagent"
		},
		"plan": {
			"color": "#72F6B2"
		},
		"build": {
			"color": "#55BBF9"
		}
	},
	"mcp": {
		"context7": {
			"type": "local",
			"command": [
				"bunx",
				"-y",
				"@upstash/context7-mcp@latest"
			],
			"enabled": true
		},
		"tavily-mcp": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"tavily-mcp"
			],
			"enabled": true
		},
		"perplexity-mcp": {
			"type": "local",
			"command": [
				"bunx",
				"-y",
				"perplexity-mcp"
			],
			"enabled": false,
			"environment": {
				"PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}",
				"PERPLEXITY_TIMEOUT_MS": "600000"
			}
		},
		"firecrawl": {
			"type": "local",
			"command": [
				"bunx",
				"-y",
				"firecrawl-mcp"
			],
			"enabled": true,
			"environment": {
				"FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
			}
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": false
		},
		"grep_app": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		}
	},
}
