{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [
		"~/.config/ocp/default/INSTRUCTIONS.md",
		"~/.config/ocp/default/SUBAGENT_GUIDE.md"
	],
	"plugin": [
		"opencode-antigravity-auth@latest",
		"opencode-claude-auth",
		"@tarquinen/opencode-dcp@latest"
	],
	"small_model": "opencode/gpt-5-nano",
	"agent": {
		"general": {
			"mode": "subagent"
		},
		"explore": {
			"mode": "subagent"
		},
		"plan": {
			"color": "#72F6B2"
		},
		"build": {
			"color": "#55BBF9"
		}
	}
}
